# ═══════════════════════════════════════════════════════
# ModelForge — Environment Variables
# Copy to .env and replace every `changeme-*` value before
# bringing the stack up. .env is git-ignored.
# ═══════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Auth ──────────────────────────────────────────────
# Required when ENVIRONMENT=production. Send as `X-API-Key` header.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MODELFORGE_API_KEY=changeme-modelforge-api-key

# ── CORS ──────────────────────────────────────────────
# Comma-separated. Avoid `*` in production — the API rejects credentials
# automatically when `*` is present.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ── Docker published ports (host) ─────────────────────
# When host :8000 or :3000 is already in use, set these before `docker compose up`.
# MODELFORGE_API_HOST_PORT=8001
# MODELFORGE_WEB_HOST_PORT=3001

# ── Database ──────────────────────────────────────────
POSTGRES_USER=modelforge
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_DB=modelforge
DATABASE_URL=postgresql+asyncpg://modelforge:changeme-postgres-password@postgres:5432/modelforge
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Inference ─────────────────────────────────────────
# Internal Docker network hostnames; not exposed to the host in production.
OLLAMA_HOST=http://ollama:11434
VLLM_HOST=http://vllm:8000
# Required when running the `gpu` profile — vLLM enforces this.
VLLM_API_KEY=changeme-vllm-api-key

# ── n8n ───────────────────────────────────────────────
# Required for credential encryption at rest (32+ random chars recommended).
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme-n8n-encryption-key-32chars-minimum-please
N8N_HOST=http://n8n:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme-n8n-admin-password
# Public URL prefix for generated webhook links (trailing slash OK). Compose maps host 5679 → n8n 5678.
N8N_WEBHOOK_URL=http://localhost:5679/
# First-time owner (browser signup). Bootstrap script: ./scripts/n8n-wait-and-login.sh
N8N_OWNER_EMAIL=admin@modelforge.local
N8N_OWNER_PASSWORD=changeme-n8n-owner-password
# API container posts evolution events here (Docker DNS hostname `n8n`).
N8N_WEBHOOK_EVOLUTION_URL=http://n8n:5678/webhook/evolution-events
# Optional — Slack nodes in bundled workflows use $env.SLACK_WEBHOOK_URL
SLACK_WEBHOOK_URL=

# ── External APIs (optional) ──────────────────────────
HF_TOKEN=
WANDB_API_KEY=
ANTHROPIC_API_KEY=

# ── Evolution Defaults ────────────────────────────────
DEFAULT_BASE_MODEL=llama3.2:3b
DEFAULT_MAX_GENERATIONS=10
DEFAULT_LORA_RANK=16
DEFAULT_LORA_ALPHA=32
DEFAULT_LEARNING_RATE=0.0002
DEFAULT_BATCH_SIZE=2

# ── Frontend (Vite) ───────────────────────────────────
# Leave empty for Docker/nginx (same-origin /api). For local Vite-only dev against a remote API, set full URL.
VITE_API_BASE_URL=
# Optional — landing “GitHub ⭐” / footer links (default https://github.com).
# VITE_GITHUB_URL=https://github.com/your-org/model-forge
# Optional — landing footer “API Docs” (default http://localhost:8001/docs when unset).
# VITE_API_DOCS_URL=https://api.example.com/docs
VITE_OLLAMA_HOST=http://localhost:11434
VITE_VLLM_HOST=http://localhost:8001
VITE_N8N_HOST=http://localhost:5679
