    {
      "id": "code-run-summary",
      "name": "Build Run Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        700
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const event = $('Normalize Payload').first().json || {};\nconst lineage = $input.first().json || {};\nconst nodes = Array.isArray(lineage.nodes) ? lineage.nodes : [];\n\nconst myRun = nodes.filter((n) => n && n.run_id === event.run_id);\nconst sample = myRun.length ? myRun : nodes;\nlet promoted = 0;\nlet discarded = 0;\nlet bestImp = -Infinity;\nlet worstReg = Infinity;\nlet startScore = null;\nlet endScore = null;\nconst scoreSeries = [];\nfor (const n of sample) {\n  const decision = String(n.decision || (n.promoted ? 'promote' : 'discard')).toLowerCase();\n  if (decision === 'promote') promoted += 1;\n  else if (decision === 'discard') discarded += 1;\n  const avg = Number(n.avg_score ?? n.champion_avg ?? n.score);\n  if (Number.isFinite(avg)) {\n    scoreSeries.push({ gen: Number(n.generation), avg });\n  }\n}\nscoreSeries.sort((a, b) => a.gen - b.gen);\nif (scoreSeries.length) {\n  startScore = scoreSeries[0].avg;\n  endScore = scoreSeries[scoreSeries.length - 1].avg;\n  for (let i = 1; i < scoreSeries.length; i++) {\n    const d = scoreSeries[i].avg - scoreSeries[i - 1].avg;\n    if (d > bestImp) bestImp = d;\n    if (d < worstReg) worstReg = d;\n  }\n}\n\nconst total = promoted + discarded;\nconst rate = total > 0 ? (promoted / total) : 0;\nconst dur = Number(event.duration_seconds || 0);\nconst minutes = Math.round(dur / 60);\nconst totalGens = Number(event.total_generations ?? event.generation_number ?? scoreSeries.length);\n\nconst slack_message = [\n  `:checkered_flag: *Run complete* \\`${event.run_id}\\``,\n  `\\u2022 Generations: ${totalGens} (\\u2705 ${promoted} promoted / \\u26d4 ${discarded} discarded, rate ${(rate * 100).toFixed(1)}%)`,\n  `\\u2022 Score: start ${startScore !== null ? startScore.toFixed(4) : 'n/a'} \\u2192 end ${endScore !== null ? endScore.toFixed(4) : 'n/a'}`,\n  `\\u2022 Best gen-over-gen: ${bestImp === -Infinity ? 'n/a' : (bestImp * 100).toFixed(2) + '%'} | Worst: ${worstReg === Infinity ? 'n/a' : (worstReg * 100).toFixed(2) + '%'}`,\n  `\\u2022 Champion: \\`${event.champion_model_id ?? 'n/a'}\\``,\n  `\\u2022 Duration: ${minutes}m`,\n].join('\\n');\n\nconsole.log('[evolution-monitor] run summary', { run_id: event.run_id, totalGens, promoted, discarded, rate });\n\nreturn [{\n  json: {\n    ...event,\n    promoted,\n    discarded,\n    promotion_rate: rate,\n    best_improvement: bestImp,\n    worst_regression: worstReg,\n    start_score: startScore,\n    end_score: endScore,\n    slack_message,\n  }\n}];\n"
      }
    },
