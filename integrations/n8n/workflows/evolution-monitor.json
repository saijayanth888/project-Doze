      "id": "code-track-discards",
      "name": "Track Consecutive Discards",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        100
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const ev = $input.first().json || {};\nconst sd = $getWorkflowStaticData('global');\nconst decision = String(ev.decision || '').toLowerCase();\nconst gen = Number(ev.generation_number ?? ev.generation ?? 0);\n\nlet streak = Number(sd.consecutive_discards || 0);\nif (decision === 'discard') {\n  streak += 1;\n} else {\n  streak = 0;\n}\nsd.consecutive_discards = streak;\nsd.last_decision = decision;\nsd.last_generation = gen;\n\nconst stuck = streak >= 3;\nconst slackText = stuck\n  ? `:red_circle: *ModelForge: Stuck* — ${streak} consecutive discards (last gen ${gen}). Consider: increase training data, change LR, or target different categories.`\n  : `*Generation ${gen} complete* | decision: \\`${decision || 'unknown'}\\` | best=${ev.best_score ?? 'N/A'} | avg=${ev.avg_score ?? ev.champion_avg ?? 'N/A'} | run=\\`${ev.run_id}\\``;\n\nconsole.log('[evolution-monitor] discards', { streak, decision, stuck });\n\nreturn [{ json: { ...ev, consecutive_discards: streak, stuck, slack_message: slackText } }];\n"
      }
    },
