    {
      "id": "code-error-severity",
      "name": "Error Severity Classifier",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        980
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const ev = $input.first().json || {};\nconst raw = String(ev.error_message ?? ev.message ?? ev.error ?? '').toLowerCase();\nlet severity = 'error';\nlet hint = 'See run logs for details.';\nif (/oom|out of memory|cuda out of memory|memory_oom/.test(raw)) {\n  severity = 'critical';\n  hint = 'Reduce batch_size, gradient_accumulation_steps, or model size.';\n} else if (/timeout|timed out|deadline/.test(raw)) {\n  severity = 'warning';\n  hint = 'Increase timeout or reduce eval scope (quick_eval).';\n} else if (/connection refused|connect timeout|connection reset|econnref|no route to host|name or service not known/.test(raw)) {\n  severity = 'warning';\n  hint = 'Check Ollama / API / DB connectivity.';\n}\n\nconst is_critical = severity === 'critical';\nconst slackPrefix = is_critical ? ':red_circle: *CRITICAL*' : (severity === 'warning' ? ':warning: *Warning*' : ':bangbang: *Error*');\nconst slack_message = `${slackPrefix} run \\`${ev.run_id ?? 'unknown'}\\` gen=${ev.generation_number ?? ev.generation ?? 'n/a'} | ${ev.error_message ?? ev.message ?? 'no message'} | ${hint}${is_critical ? '\\nRun will be stopped.' : ''}`;\n\nconsole.log('[evolution-monitor] error severity', { severity, is_critical });\n\nreturn [{ json: { ...ev, severity, is_critical, hint, slack_message } }];\n"
      }
    },
