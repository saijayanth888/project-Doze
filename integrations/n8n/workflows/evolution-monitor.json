    {
      "id": "code-perf-analysis",
      "name": "Performance Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        380
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Combine the original webhook event (still on item 0 of the champion branch)\n// with the eval scores fetched in the previous node.\nconst event = $('Normalize Payload').first().json || {};\nconst scoresResp = $input.first().json || {};\nconst trends = Array.isArray(scoresResp)\n  ? scoresResp\n  : Array.isArray(scoresResp.trends)\n  ? scoresResp.trends\n  : Array.isArray(scoresResp.scores)\n  ? scoresResp.scores\n  : [];\n\n// Build per-generation per-benchmark map for promoted gens.\nconst byGen = {};\nfor (const t of trends) {\n  if (!t || !t.promoted) continue;\n  const gen = Number(t.generation);\n  if (!Number.isFinite(gen)) continue;\n  if (!byGen[gen]) byGen[gen] = {};\n  byGen[gen][t.benchmark] = Number(t.score ?? t.child_score ?? 0);\n}\n\nconst promotedGens = Object.keys(byGen).map(Number).sort((a, b) => b - a);\nconst latest = byGen[promotedGens[0]] || {};\nconst prev = byGen[promotedGens[1]] || {};\n\nconst movers = [];\nfor (const k of Object.keys(latest)) {\n  const cur = latest[k];\n  const old = prev[k];\n  if (Number.isFinite(old)) movers.push({ benchmark: k, delta: cur - old, current: cur });\n}\nmovers.sort((a, b) => b.delta - a.delta);\n\nconst regressions = movers.filter((m) => m.delta < -0.005);\nconst hasRegression = regressions.length > 0;\nconst topMover = movers[0];\n\nconst latestAvg = Object.values(latest).length\n  ? Object.values(latest).reduce((a, b) => a + b, 0) / Object.values(latest).length\n  : (event.champion_avg ?? null);\nconst prevAvg = Object.values(prev).length\n  ? Object.values(prev).reduce((a, b) => a + b, 0) / Object.values(prev).length\n  : null;\nconst overallDelta = latestAvg !== null && prevAvg !== null ? latestAvg - prevAvg : null;\n\nconst genNum = Number(event.generation_number ?? event.generation ?? promotedGens[0] ?? 0);\nconst regBenches = regressions.map((r) => `${r.benchmark} ${(r.delta * 100).toFixed(1)}%`).join(', ');\nconst topMoverStr = topMover ? `${topMover.benchmark} ${(topMover.delta * 100).toFixed(1)}%` : 'n/a';\nconst overallStr = overallDelta !== null ? `${(overallDelta * 100).toFixed(2)}%` : 'n/a';\n\nconst slack_ok = `:trophy: *Gen ${genNum} is new champion* — avg ${latestAvg !== null ? latestAvg.toFixed(4) : 'n/a'} (\\u0394 ${overallStr}). Top mover: ${topMoverStr}. All benchmarks improved or held.`;\nconst slack_warn = `:warning: *Gen ${genNum} promoted with regression* on ${regBenches}. Overall \\u0394 ${overallStr}. Top mover: ${topMoverStr}.`;\n\nconsole.log('[evolution-monitor] champion analysis', { genNum, hasRegression, overallDelta, regBenches, topMoverStr });\n\nreturn [{\n  json: {\n    ...event,\n    latest_scores: latest,\n    prev_scores: prev,\n    movers,\n    regressions,\n    has_regression: hasRegression,\n    overall_delta: overallDelta,\n    latest_avg: latestAvg,\n    slack_message: hasRegression ? slack_warn : slack_ok,\n    slack_message_ok: slack_ok,\n    slack_message_warn: slack_warn,\n    deploy_payload_json: JSON.stringify({\n      event_type: 'champion_deployed_request',\n      run_id: event.run_id,\n      generation: genNum,\n      champion_model_id: event.champion_model_id,\n      scores: latest,\n      avg: latestAvg,\n    }),\n  }\n}];\n"
      }
    },
