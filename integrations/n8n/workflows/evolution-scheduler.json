        "jsonBody": "={{ JSON.stringify({ text: `:rocket: *ModelForge: Evolution started* | base=${$json.config?.base_model ?? $env.EVOLUTION_BASE_MODEL} | max_gens=${$json.config?.max_generations} | max_samples=${$json.config?.max_samples} | plateau=${$json.plateau_detected} | regression_risk=${$json.regression_risk}` }) }}",
        "options": {
          "timeout": 5000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "code-skip-reason",
      "name": "Build Skip Reason",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        660
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const j = $input.first().json || {};\nconst reasons = j.skip_reasons || (Array.isArray(j.skip_reasons_list) ? j.skip_reasons_list.join(', ') : 'unknown');\nconsole.log('[scheduler] skipped:', reasons);\nreturn [{\n  json: {\n    skipped: true,\n    skip_reasons: reasons,\n    slack_message: `:warning: *ModelForge: Evolution skipped* — ${reasons}`,\n    detected_at: new Date().toISOString(),\n  }\n}];\n"
      }
    },
