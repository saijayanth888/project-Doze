    {
      "id": "get-gpu-status",
      "name": "GET GPU Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        860,
        540
      ],
      "parameters": {
        "method": "GET",
        "url": "http://api:8000/api/system/gpu",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "pAuhGy_kTkDowUta8Zo0_komj41RU-q7nMFQG6womEY"
            }
          ]
        },
        "options": {
          "timeout": 20000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "code-preflight",
      "name": "GPU Preflight Checks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        540
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const gpu = $input.first().json || {};\nconst tempRaw = gpu.temperature ?? gpu.temperature_c ?? gpu.gpu_temp;\nconst memUsed = parseFloat(gpu.memory_used);\nconst memTotal = parseFloat(gpu.memory_total);\nconst memUtil = (Number.isFinite(memUsed) && Number.isFinite(memTotal) && memTotal > 0)\n  ? memUsed / memTotal\n  : null;\n\nconst checks = {\n  gpu_available: gpu.gpu_available === true,\n  temp_ok: tempRaw === undefined || tempRaw === null || parseFloat(tempRaw) < 80,\n  memory_ok: memUtil === null || memUtil < 0.5,\n};\n\nconst all_pass = Object.values(checks).every((v) => v === true);\n\nconst skip_reasons = [];\nif (!checks.gpu_available) skip_reasons.push('GPU unavailable');\nif (!checks.temp_ok) skip_reasons.push(`GPU too hot (${tempRaw}\\u00b0C)`);\nif (!checks.memory_ok) skip_reasons.push(`GPU memory too high (${memUsed}/${memTotal})`);\n\nconsole.log('[scheduler] preflight', { checks, all_pass, skip_reasons });\n\nreturn [{\n  json: {\n    gpu,\n    checks,\n    all_pass,\n    skip_reasons: skip_reasons.join(', '),\n    skip_reasons_list: skip_reasons,\n    memory_utilization: memUtil,\n    temperature: tempRaw,\n  }\n}];\n"
      }
    },
    {
      "id": "if-all-pass",
      "name": "All Preflight Checks Pass?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1300,
        540
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "all-pass",
              "leftValue": "={{ $json.all_pass }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "get-eval-scores",
      "name": "GET Eval Scores",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        420
      ],
      "parameters": {
        "method": "GET",
        "url": "http://api:8000/api/eval/scores",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "pAuhGy_kTkDowUta8Zo0_komj41RU-q7nMFQG6womEY"
            }
          ]
        },
        "options": {
          "timeout": 15000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "code-plateau",
      "name": "Plateau Analysis + Adaptive Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        420
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const raw = $input.first().json || {};\nconst trends = Array.isArray(raw)\n  ? raw\n  : Array.isArray(raw.trends)\n  ? raw.trends\n  : Array.isArray(raw.scores)\n  ? raw.scores\n  : [];\n\nconst promoted = {};\nfor (const t of trends) {\n  if (!t || !t.promoted) continue;\n  const gen = Number(t.generation);\n  const score = Number(t.score ?? t.child_score ?? t.avg_score);\n  if (!Number.isFinite(gen) || !Number.isFinite(score)) continue;\n  if (!promoted[gen]) promoted[gen] = [];\n  promoted[gen].push(score);\n}\n\nconst genAvgs = Object.entries(promoted)\n  .map(([gen, arr]) => ({\n    gen: Number(gen),\n    avg: arr.reduce((a, b) => a + b, 0) / arr.length,\n  }))\n  .sort((a, b) => b.gen - a.gen)\n  .slice(0, 5);\n\nlet plateau_detected = false;\nlet regression_risk = false;\nlet adaptive_max_gens = Number($env.EVOLUTION_MAX_GENS || 10);\nlet adaptive_max_samples = 3000;\n\nif (genAvgs.length >= 3) {\n  const recent3 = genAvgs.slice(0, 3);\n  const improvement = recent3[0].avg - recent3[2].avg;\n  if (improvement < 0.002) {\n    plateau_detected = true;\n    adaptive_max_gens = 15;\n    adaptive_max_samples = 5000;\n  }\n}\n\n// Detect regression risk: >2 benchmarks dropped in latest non-promoted gen.\nconst byGenBench = {};\nfor (const t of trends) {\n  const gen = Number(t.generation);\n  if (!Number.isFinite(gen)) continue;\n  if (!byGenBench[gen]) byGenBench[gen] = {};\n  byGenBench[gen][t.benchmark] = Number(t.score ?? t.child_score ?? 0);\n}\nconst gens = Object.keys(byGenBench).map(Number).sort((a, b) => b - a);\nif (gens.length >= 2) {\n  const last = byGenBench[gens[0]] || {};\n  const prev = byGenBench[gens[1]] || {};\n  let regressions = 0;\n  for (const k of Object.keys(last)) {\n    if (prev[k] !== undefined && last[k] < prev[k] - 0.005) regressions += 1;\n  }\n  if (regressions > 2) regression_risk = true;\n}\n\nconst body = {\n  base_model: $env.EVOLUTION_BASE_MODEL || 'llama3.2:3b',\n  max_generations: adaptive_max_gens,\n  max_samples: adaptive_max_samples,\n};\n\nconsole.log('[scheduler] plateau analysis', { plateau_detected, regression_risk, genAvgs, body });\n\nreturn [{\n  json: {\n    plateau_detected,\n    regression_risk,\n    gen_averages: genAvgs,\n    config: body,\n    body_json: JSON.stringify(body),\n    summary: `plateau=${plateau_detected} regression_risk=${regression_risk} max_gens=${adaptive_max_gens} max_samples=${adaptive_max_samples}`,\n  }\n}];\n"
      }
    },
